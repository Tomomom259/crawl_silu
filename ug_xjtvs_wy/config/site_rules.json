  "drop_text_patterns": [
    "تەۋسىيە",
    "相关阅读",
    "责任编辑",
    "来源",
    "分享到",
    "看电视",
    "听广播"
  ],
  "extraction": {
    "title_selectors": [
      "h1::text",
      ".article-title::text",
      ".news-title::text",
      "meta[property='og:title']::attr(content)",
      "title::text"
    ],
    "publish_time_selectors": [
      "time::text",
      ".publish-time::text",
      ".time::text",
      ".date::text",
      "meta[property='article:published_time']::attr(content)"

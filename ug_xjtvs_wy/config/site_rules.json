      "div > p",
      "section p",
      "li"
    ],
    "remove_selectors": [
      "script",
      "style",
      "noscript",
      "iframe",
      "video",
      "audio",
      ".share",
      ".recommend",
      ".related",
      ".footer",
      ".header",
      ".nav",
      ".player",

    "\\/video",
    "\\/audio",
    "\\/radio",
    "\\/tv",
    "\\/watch",
    "\\/listen",
    "\\/player",
    "\\/download",
    "\\/app",
    "\\/search",
    "\\/comment",
    "\\/login",
    "\\/api",
    "\\.m3u8$",
    "\\.mp4$",
    "\\.mp3$",
    "\\.jpg$",
    "\\.jpeg$",
    "\\.png$",
    "\\.webp$",
    "\\.gif$",
    "\\.svg$"
  ],
  "allow_article_url_patterns": [
    "\\/20\\d{2}\\/\\d{2}\\/\\d{2}\\/",
    "\\/detail",
    "\\/article",
    "\\/content",
    "\\/news\\/\\d+",
    "\\.html?$"
  ],
  "deny_article_url_patterns": [
    "\\/live",
    "\\/video",
    "\\/audio",
    "\\/radio",
    "\\/tv",
    "\\/watch",
    "\\/listen",
    "\\/player",
    "\\/photo",
    "\\/gallery"
